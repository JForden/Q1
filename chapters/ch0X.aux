\@writefile{lof}{\contentsline {figure}{\numberline {3.6}{\ignorespaces Building the feature matrix row by row. For each dollar bar \texttt  {i}, we compute the technical indicators that describe market conditions at that moment, then apply the Triple-Barrier Method to assign the label $y$.}}{35}{figure.caption.16}\protected@file@percent }
\newlabel{lst:feature-matrix-loop}{{3.6}{35}{Building the feature matrix row by row. For each dollar bar \texttt {i}, we compute the technical indicators that describe market conditions at that moment, then apply the Triple-Barrier Method to assign the label $y$}{figure.caption.16}{}}
\def\@LN@column{1}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.5.2}The Confusion Matrix}{35}{subsection.3.5.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3.7}{\ignorespaces Two approaches to splitting the feature matrix into training and test sets. \textbf  {Top (correct):} A temporal split preserves chronological order --- the model trains on 2018--2021 data and is evaluated on 2022 data it has never seen. \textbf  {Bottom (wrong):} A random shuffle interleaves future and past rows, allowing the model to learn from data that postdates the observations it is supposedly predicting. This is \textbf  {data leakage}: the backtest appears excellent, but the model has seen the future and will fail immediately in live trading.}}{36}{figure.caption.17}\protected@file@percent }
\newlabel{fig:training-data-split}{{3.7}{36}{Two approaches to splitting the feature matrix into training and test sets. \textbf {Top (correct):} A temporal split preserves chronological order --- the model trains on 2018--2021 data and is evaluated on 2022 data it has never seen. \textbf {Bottom (wrong):} A random shuffle interleaves future and past rows, allowing the model to learn from data that postdates the observations it is supposedly predicting. This is \textbf {data leakage}: the backtest appears excellent, but the model has seen the future and will fail immediately in live trading}{figure.caption.17}{}}
\newlabel{fig:train-test-split}{{3.7}{36}{Two approaches to splitting the feature matrix into training and test sets. \textbf {Top (correct):} A temporal split preserves chronological order --- the model trains on 2018--2021 data and is evaluated on 2022 data it has never seen. \textbf {Bottom (wrong):} A random shuffle interleaves future and past rows, allowing the model to learn from data that postdates the observations it is supposedly predicting. This is \textbf {data leakage}: the backtest appears excellent, but the model has seen the future and will fail immediately in live trading}{figure.caption.17}{}}
