\def\@LN@column{1}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.4.4}Finding Labels: The Triple-Barrier Method}{30}{subsection.3.4.4}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {3.4.5}Meta Labeling}{30}{subsection.3.4.5}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3.4}{\ignorespaces The Triple-Barrier Method. A trade opens at the entry point (blue dot) and the price path is tracked bar-by-bar within a corridor bounded by a profit barrier (red, dashed), a stop-loss barrier (gray, dashed), and a time expiration (vertical, dashed). The label $y$ is assigned based on whichever barrier the price hits first. Here, the price dips dangerously close to the stop-loss before recovering and eventually hitting the profit barrier---earning label $y = 1$. A fixed-horizon method would assign the same label without ever ``seeing'' the near-miss, illustrating why the path matters for realistic trade labeling.}}{31}{figure.caption.13}\protected@file@percent }
\newlabel{fig:triple-barrier}{{3.4}{31}{The Triple-Barrier Method. A trade opens at the entry point (blue dot) and the price path is tracked bar-by-bar within a corridor bounded by a profit barrier (red, dashed), a stop-loss barrier (gray, dashed), and a time expiration (vertical, dashed). The label $y$ is assigned based on whichever barrier the price hits first. Here, the price dips dangerously close to the stop-loss before recovering and eventually hitting the profit barrier---earning label $y = 1$. A fixed-horizon method would assign the same label without ever ``seeing'' the near-miss, illustrating why the path matters for realistic trade labeling}{figure.caption.13}{}}
