\@writefile{lof}{\contentsline {figure}{\numberline {3.3}{\ignorespaces The course data pipeline. Each stage transforms the raw market data into a form the machine learning model can use. \textit  {Tick Data} captures every trade event; \textit  {Dollar Bars} resample that stream into uniform economic time; \textit  {Fractional Differentiation} enforces stationarity while preserving trend memory; and the \textit  {Feature Matrix} encodes our trading hypotheses as measurable inputs. This chapter picks up at the final stage.}}{28}{figure.caption.11}\protected@file@percent }
\newlabel{fig:data-pipeline}{{3.3}{28}{The course data pipeline. Each stage transforms the raw market data into a form the machine learning model can use. \textit {Tick Data} captures every trade event; \textit {Dollar Bars} resample that stream into uniform economic time; \textit {Fractional Differentiation} enforces stationarity while preserving trend memory; and the \textit {Feature Matrix} encodes our trading hypotheses as measurable inputs. This chapter picks up at the final stage}{figure.caption.11}{}}
\@writefile{lot}{\contentsline {table}{\numberline {3.5}{\ignorespaces A financial feature matrix: each row represents one dollar volume bar, and each column represents a measurable signal at that moment in time. The columns are \textbf  {features} $x$ }}{29}{table.caption.12}\protected@file@percent }
\newlabel{tab:feature-matrix}{{3.5}{29}{A financial feature matrix: each row represents one dollar volume bar, and each column represents a measurable signal at that moment in time. The columns are \textbf {features} $x$}{table.caption.12}{}}
